{
  "comment"  : "cf http://usejsdoc.org/about-configuring-jsdoc.html",
  "tags"     : {
    "allowUnknownTags": true
  },
  "source"   : {
    "includeIgnored": ["./app/_typedef.doc.js"],
    "include": ["./app/srcClient", "./app/srcClient/README.md"],
    "includePattern": ".+\\.(js)$",
    "excludePattern": "(.+\\.bak\\.js|.+\\.bundle\\.js)"
  },
  "plugins"  : [
    "plugins/markdown",
    "plugins_sup/ngdoc"
  ],
  "markdown" : {
    "parser"  : "gfm",
    "hardwrap": true
  },
  "templates": {
    "applicationName": "plugins sesatheque",
    "disqus"         : "",
    "googleAnalytics": "",
    "openGraph"      : {
      "title"    : "",
      "type"     : "website",
      "image"    : "",
      "site_name": "",
      "url"      : ""
    },
    "meta"           : {
      "title"      : "",
      "description": "",
      "keyword"    : ""
    }

  },
  "opts"     : {
    "destination": "./documentation/plugins",
    "recurse"    : true,
    "private"    : false
  }
}
