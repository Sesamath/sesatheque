{
  "comment"  : "cf http://usejsdoc.org/about-configuring-jsdoc.html",
  "tags"     : {
    "allowUnknownTags": true
  },
  "source"   : {
    "include":["./app/server", "./doc_src", "./README.md"],
    "includePattern": ".+\\.js$"
  },
  "plugins"  : [
    "plugins/markdown",
    "plugins_sup/ngdoc"
  ],
  "markdown" : {
    "parser"  : "gfm",
    "hardwrap": true
  },
  "templates": {
    "applicationName": "sesatheque",
    "disqus"         : "",
    "googleAnalytics": "",
    "openGraph"      : {
      "title"    : "",
      "type"     : "website",
      "image"    : "",
      "site_name": "",
      "url"      : ""
    },
    "meta"           : {
      "title"      : "",
      "description": "",
      "keyword"    : ""
    }

  },
  "opts"     : {
    "destination": "./documentation",
    "tutorials": "./doc_src",
    "recurse"    : true,
    "private"    : false
  }
}
