{
  "comment"  : "cf http://usejsdoc.org/about-configuring-jsdoc.html",
  "tags"     : {
    "allowUnknownTags": true
  },
  "source"   : {
    "include": [ "./node_modules/lassi/source", "./node_modules/lassi/example", "./node_modules/lassi/README.md"],
    "includePattern": ".+\\.(js|md)$",
    "excludePattern": "node_modules/lassi/node_modules"
  },
  "plugins"  : ["plugins/markdown"],
  "markdown" : {
    "parser"  : "gfm",
    "hardwrap": true
  },
  "templates": {
    "applicationName": "Lassi",
    "disqus"         : "",
    "googleAnalytics": "",
    "openGraph"      : {
      "title"    : "",
      "type"     : "website",
      "image"    : "",
      "site_name": "",
      "url"      : ""
    },
    "meta"           : {
      "title"      : "",
      "description": "",
      "keyword"    : ""
    }

  },
  "opts"     : {
    "destination": "./documentation/lassi",
    "recurse"    : true,
    "private"    : false
  }
}
