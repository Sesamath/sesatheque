{
  "comment"  : "cf http://usejsdoc.org/about-configuring-jsdoc.html",
  "tags"     : {
    "allowUnknownTags": true
  },
  "source"   : {
    "include":["./node_modules/sesatheque-client"],
    "includePattern": ".+\\.(js|md)$",
    "excludePattern": "(node_modules|public|qxApps|.+\\.bak\\.js)"
  },
  "plugins"  : [
    "plugins/markdown",
    "plugins_sup/ngdoc"
  ],
  "markdown" : {
    "parser"  : "gfm",
    "hardwrap": true
  },
  "templates": {
    "applicationName": "apiClient",
    "disqus"         : "",
    "googleAnalytics": "",
    "openGraph"      : {
      "title"    : "",
      "type"     : "website",
      "image"    : "",
      "site_name": "",
      "url"      : ""
    },
    "meta"           : {
      "title"      : "",
      "description": "",
      "keyword"    : ""
    }

  },
  "opts"     : {
    "destination": "./documentation/modules/apiClient",
    "recurse"    : true,
    "template"   : "./jaguarjs-jsdoc",
    "private"    : false
  }
}
