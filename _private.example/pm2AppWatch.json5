{
  /**
   * Pas trouvé le moyen d'arriver à avoir du watch en dev et pas en prod sans fichier de conf séparé
   * créer un environnement custom pour préciser watch ne marche pas
   */
  "apps" : [
    {
      "name"             : "sesatheque",
      "script"           : "app/index.js",
      "log_date_format"  : "YYYY-MM-DD HH:mm:ss",
      "exec_mode"        : "cluster",
      "exec_interpreter" : "node",
      "node_args"        : [],
      "instances"        : "2",
      "watch"            : ["app", "test"],
      "ignore_watch"     : ["app/main/public", "app/ressource/public"],
      "pid_file"         : "sesatheque.pid",
      "error_file"       : "logs/sesatheque-err.log",
      "out_file"         : "logs/sesatheque-out.log",

      "env": {
        "PORT"  : 3001
      },
      "env_dev" : {
        "NODE_ENV": "dev"
      },
      "env_prod" : {
        "NODE_ENV": "prod"
      }
    }
  ]
}
