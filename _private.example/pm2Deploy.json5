{
  /**
   * Configuration du déploiement, à priori uniquement en local
   * (ou éventuellement dev si on lance des déploiement dev -> prod depuis le dev)
   * @see https://github.com/Unitech/PM2/blob/master/ADVANCED_README.md#deployment-pm2--090
   */
  deploy : {
    prod : {
      user : "sesatheque",
      host : "0.0.0.0",
      ref  : "origin/master",
      repo : "git@src.sesamath.net:sesatheque#master",
      path : "/var/www/sesatheque", // pm2 deploy _private/pm2Deploy.json5 prod setup va créer un sous-dossier source
      "post-deploy" : "npm install && pm2 startOrRestart _private/pm2App.json5 --env prod"
    },
    dev : {
      user : "sesatheque",
      host : "0.0.0.0",
      ref  : "origin/master",
      repo : "git@src.sesamath.net:sesatheque#master",
      path : "/var/www/sesatheque",
      "post-deploy" : "npm install && pm2 startOrGracefulReload _private/pm2App.json5 --env dev"
    }
  }
}
