<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="description" content="Médiathèque de ressources pour l'éducation">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" sizes="16x16" href="/favicon.png?{version}">
    <link rel="stylesheet" href="/styles/page.css?{version}">
    {head|s}
</head>
<body>

{!Cf http://www.w3.org/TR/wai-aria/roles pour la liste des roles possibles !}
<header id="header" role="banner">
  <a href="/"><img src="/images/sesatheque.png?{version}" width="250" height="48" alt="logo"></a>
  <nav class="navigation fr" role="navigation">
    {navigation|s}
    {authBloc|s}
  </nav>
</header>

<div id="main" role="document">
  {!titre flottant seulement si on a des actions, qui devront alors gérer le clearfix!}
  {?titre}<h1 {?actions}class="fl"{/actions}>{titre}</h1>{/titre}
  {actions|s}
  {?error}<p class="error">{error}</p>{/error}
  {errors|s}
  {warnings|s}
  {flashBloc|s}
  {blocsFirst|s}
  {contentBloc|s}
  {blocs|s}
  {! jsBloc poussé juste avant /body !}
</div>

<footer id="footer">
  <ul class="fl" role="navigation">
    <li><a href="#" onclick="alert('Cette page reste à rédiger')">Infos légales</a></li>
    <li><a href="http://www.sesamath.net">Association Sésamath</a></li>
  </ul>
  <p class="fr">
    Propulsé par <a href="#" onclick="alert('Le site http://sesatheque.sesamath.net va venir')">Sésathèque</a>
    {version}
  </p>
</footer>

{jsBloc|s}
</body>
</html>
