<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="description" content="Médiathèque de ressources pour l'éducation">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" sizes="16x16" href="/favicon.png?{version}">
    <link rel="stylesheet" href="/page.css?{version}">
    {head|s}
</head>
<body>

{!Cf http://www.w3.org/TR/wai-aria/roles pour la liste des roles possibles !}

<div id="root" role="document"></div>
<div>
  {!titre flottant seulement si on a des actions, qui devront alors gérer le clearfix!}
  {?titre}<h1 {?actions}class="fl"{/actions}>{titre}</h1>{/titre}
  {actions|s}
  {?error}<p class="error">{error}</p>{/error}
  {errors|s}
  {warnings|s}
  {flashBloc|s}
  {blocsFirst|s}
  {contentBloc|s}
  {blocs|s}
  {! jsBloc poussé juste avant /body !}
</div>

{jsBloc|s}
</body>
</html>
