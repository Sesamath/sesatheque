<form
  {?name}name="{name}"{/name}
  {?method}method="{method}"{/method}
  {?id}id="{id}"{/id}
>
  {#warnings}<p class="warning">{.}</p>{/warnings}

  {! Attention à masquer l'élément id du form (et ses autres propriétés), sinon le field pourrait hériter de ces propirétés
     On masque le contexte, en mettant en contexte chaque élément de form.groups et en parent une variable qui n'existe pas ("rien")
     cf https://github.com/linkedin/dustjs/wiki/Dust-Tutorial#Explicit_context_setting !}
  {#groups:rien}{>"form/group" /}{/groups}
  {#fields:rien}{>"form/field" /}{/fields}
</form>
