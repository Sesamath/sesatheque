{
  "extends": "../../../.jshintrc",
  "browser": true,
  "asi": true,
  "bitwise": true,
  "forin": true,
  "freeze": true,
  "immed": true,
  "maxlen": 160,
  "newcap": true,
  "undef": true,
  "unused": true,
  "indent": 2,
  "predef" : ["define", "require", "log"],
  "globals": ["define", "require", "log"]
}