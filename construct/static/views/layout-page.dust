<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="description" content="Médiathèque de ressources pour l'éducation">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" sizes="16x16" href="/favicon.png">
    <link rel="stylesheet" href="/styles/page.css">
    {head|s}
</head>
<body>

{!Cf http://www.w3.org/TR/wai-aria/roles pour la liste des roles possibles !}
<header id="header" role="banner">
  <a href="/"><img src="/images/sesatheque.png" width="250" height="48" alt="logo"></a>
  <nav class="navigation fr" role="navigation">
    {navigation|s}
    {authBloc|s}
  </nav>
</header>

<div id="main" role="document">
  {?title}<h1 class="fl">{title}</h1>{/title}
  {errors|s}
  {warnings|s}
  {flashBloc|s}
  {contentBloc|s}
</div>

<footer id="footer">
  <ul class="fl" role="navigation">
    <li><a href="#">Infos légales</a></li>
    <li><a href="http://www.sesamath.net">Association Sésamath</a></li>
  </ul>
  <p class="fr">
    Propulsé par <a href="http://sesatheque.sesamath.net">Sésathèque</a>
  </p>
</footer>

{#jsBloc}{.|s}{/jsBloc}
</body>
</html>
