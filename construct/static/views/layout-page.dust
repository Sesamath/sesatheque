<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="description" content="Médiathèque de ressources pour l'éducation">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" sizes="16x16" href="/favicon.png">
    <link href="/mdl/localfonts.css" rel="stylesheet">
    <link rel="stylesheet" href="/mdl/material.min.css">
    <link rel="stylesheet" href="/styles/page.css">
    {head|s}
</head>
<body>
<div class="mdl-layout mdl-js-layout">

  <header class="mdl-layout__header mdl-layout__header--scroll">
    <div class="mdl-layout__header-row">
      <a href="/"><img src="/images/sesatheque.png" alt="logo"></a>
      <div class="mdl-layout-spacer"></div>
      <nav class="mdl-navigation">
        {navigation|s}
        {authBloc|s}
      </nav>
    </div>
  </header>

  <main class="mdl-layout__content">
    {errors|s}
    {warnings|s}
    {flashBloc|s}
    <div class="mdl-card mdl-shadow--2dp main-card">
      {contentBloc|s}
    </div>
  </main>

  <footer class="mdl-mini-footer">
    <div class="mdl-mini-footer--left-section">
      <ul class="mdl-mini-footer--link-list">
        <li><a href="#">Infos légales</a></li>
        <li><a href="http://www.sesamath.net">Association Sésamath</a></li>
      </ul>
    </div>
    <div class="mdl-mini-footer--right-section">
      <ul class="mdl-mini-footer--link-list">
        <li>Propulsé par <a href="http://sesatheque.sesamath.net">Sésathèque</a></li>
      </ul>
    </div>
  </footer>

</div>

<script src="/mdl/material.min.js"></script>
{#jsBloc}{.|s}{/jsBloc}
</body>
</html>
