<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{?title}{title}{:else}Ressource Sésamath{/title}</title>
    <style type="text/css" >
        .has-errors {margin: 1em; background-color: #fff; color: #b00;}
    </style>
    {head|s}
</head>
<body>
{?error}<p class="has-error">{error}</p>{/error}
{#errors}<p class="has-error">{.}</p>{/errors}
{#flashBloc}{.|s}{/flashBloc}
{#contentBloc}{.|s}{/contentBloc}
</body>
</html>
