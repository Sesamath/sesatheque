{! Ce bloc partiel rend un input text, il prend (dans un objet o) les variables :
        o.name  : la valeur à mettre dans l'attribut name
        o.id    : id html
        o.value : le texte qui initialisera le champ
    et facultativement
        o.errors : une liste de messages d'erreur à afficher au dessus de l'input
        o.required (booléen)
    avec aussi les attributs éventuels
        o.label : texte à afficher au dessus de l'input
        o.readonly (booléen)
        o.hidden (booléen)
    et ces autres attributs éventuels passé par le template parent (pas dans l'objet)
        class : classes css qui remplaceront la classe par défaut
        maxlength
        size
        width
!}

<input type="{?o.hidden}hidden{:else}text{/o.hidden}"
       name="{o.name}"
       {?o.id}id="form-{o.id}"{:else}{?id}id="form-{id}"{/id}{/o.id}
       class="{?class}{class}{:else}form-control{/class}"
       {?o.label}placeholder="{o.label}"{/o.label}
       {?o.value}value="{o.value}"{/o.value}
       {?o.readonly}readonly="readonly"{/o.readonly}
       {?maxlength}maxlength="{maxlength}"{/maxlength}
       {?size}size="{size}"{/size}
       {?width}width="{width}"{/width}
/>
