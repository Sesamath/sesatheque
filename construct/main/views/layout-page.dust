<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>{?title}{title}{:else}Bibliothèque Sésamath{/title}</title>

    <script type="text/javascript" src="/vendors/jquery/jquery.2.1.js"></script>
    <script type="text/javascript" src="/vendors/bootstrap/js/bootstrap.min.js"></script>
    <!--script type="text/javascript" src="/scripts/main.js"></script-->
    <link type="text/css" rel="stylesheet" href="/vendors/bootstrap/css/bootstrap.min.css" />
    <link type="text/css" rel="stylesheet" href="/vendors/normalize.css" />
    <link type="text/css" rel="stylesheet" href="/styles/main.css" media="all" />
    <link type="text/css" rel="stylesheet" href="/styles/ressources.css" media="all" />
</head>
<body>

  <div id="header">
    <div class="container">
      {>header/}
    </div>
  </div>

  <div id="body" class="container">
  {#flashBloc}{.|s}{/flashBloc}
    <div class="row">
        <div class="col-md-3" id="auth">
            {#authBloc}{.|s}{:else}pas de authBloc{/authBloc}
        </div>
        <div class="col-md-3" id="sidebar">
        {#sidebar}{.|s}{/sidebar}
        </div>
        <div id="content" class="col-md-9">
        {#content}{.|s}{/content}
        </div>
      </div>
  </div>

</body>
</html>
