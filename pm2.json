{
  "comment1": "Conf PM2 pour un usage de dev en local",
  "comment2": "Cf https://github.com/Unitech/pm2#usagefeatures",
  "comment3": "le watch ne surveille que construct, lancer pm2 restart all sinon",
  "comment4": "(attention, chez moi le globbing ** empêche pm2 de finir le démarrage)",
  "apps": [
    {
      "name": "sesatheque",
      "env": {},
      "NODE_ENV": "development",
      "log_date_format": "YYYY-MM-DD HH:mm:ss.SSS",
      "exec_mode": "cluster_mode",
      "instances": "2",
      "exec_interpreter": "node",
      "script": "construct/index.js",
      "node_args": [],
      "watch": ["construct"],
      "ignore_watch" : ["construct/qxApps", "construct/*/public"],
      "pid_file": "./logs/sesatheque.pid",
      "error_file": "./logs/error.log",
      "out_file": "./logs/stdout.log"
    }
  ]
}
        