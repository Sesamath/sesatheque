#!/bin/bash

set -u

dirInitial="$PWD"

function fin() {
  cd "$dirInitial"
}

function usage() {
  local exitCode=${1:-0}
  echo "Compile notre css à partir de app/staticStylesSrc/page.less"
  exit $exitCode
}

# on veut exécuter fin avant de sortir
trap fin EXIT

cd $(dirname $0)/../
dirApp=$PWD
dirBuild="$dirApp/build"
LESSC="$dirApp/node_modules/less/bin/lessc"
dirSrc="$dirApp/app/server/src/styles"

# sans options on lance en dev
$LESSC --clean-css="--compatibility=ie8" --source-map=$dirBuild/page.map $dirSrc/page.less $dirBuild/page.css \
  && $LESSC --clean-css="--compatibility=ie8" --source-map=$dirBuild/iframe.map $dirSrc/iframe.less $dirBuild/iframe.css \
  && echo "OK" \
  || echo "KO"
