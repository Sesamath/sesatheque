#!/bin/bash

set -u

dirInitial="$PWD"

function fin() {
  cd "$dirInitial"
}

function usage() {
  local exitCode=${1:-0}
  echo "Compile require.js avec notre config"
  exit $exitCode
}

# on veut exécuter fin avant de sortir
trap fin EXIT

[ "${1:-}" == "-h" -o "${1:-}" == "--help" ] && usage

cd $(dirname $0)/../
dirApp=$PWD

tmp=/tmp/$(basename $0)
src=node_modules/requirejs/require.js
dst=construct/static/public/vendors/requirejs/require.min.js
echo -n "$dst "
# on récupère la conf sans le define de fin qui n'aime pas être concaténé tel quel
sed -e '/BEGIN CUT/, /END CUT/ d; s@// IF CUT@@g;' construct/ressource/public/initRequire.js > $tmp
node_modules/.bin/uglifyjs $src $tmp --compress --mangle > $dst && echo ok || echo KO
rm -f $tmp
