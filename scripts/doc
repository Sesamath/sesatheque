#!/bin/bash

set -u

dirInitial="$PWD"
dirApp=$(dirname $0)/../

function fin() {
  cd "$dirInitial"
}

function usage() {
  local exitCode=${1:-0}
  echo "Lance la génération de la documentation"
  echo "Une option obligatoire parmi"
  echo "  -a : toutes les documentations"
  echo "  -h : afficher cette aide"
  echo "  -l : documentation de lassi"
  echo "  -p : documentation des plugins"
  echo "  -r : documentation de l'api REST"
  echo "  -s : documentation du code serveur"
  exit $exitCode
}

# on veut exécuter fin avant de sortir
trap fin EXIT

cd "$dirApp"

# sans options on l'aide
[ $# -lt 1 ] && usage

# vérif de jsdoc
jsdoc=node_modules/.bin/jsdoc
[ ! -x $jsdoc ] && echo "$jsdoc n'est pas exécutable" >&2 && exit 1

# check des options
while getopts "ahlprs" OPTION
do
  case $OPTION in
    a) for f in jsdoc/jsdoc*.json; do jsdoc -c $f ; done ;;
    h) usage;;
    l) $jsdoc -c jsdoc/jsdocLassi.json;;
    p) $jsdoc -c jsdoc/jsdocPlugins.json;;
    r) $jsdoc -c jsdoc/jsdocRestApi.json;;
    s) $jsdoc -c jsdoc/jsdocApp.json;;
    *) usage 1;;
  esac
done

fin
