{
  "name": "Sesatheque",
  "version": "1.1.0",
  "engines": {
    "node": ">6"
  },
  "private": true,
  "license": "AGPL-3.0",
  "repository": {
    "type": "git+ssh",
    "url": "git@src.sesamath.net:sesatheque"
  },
  "scripts": {
    "build": "webpack",
    "build:css": "./scripts/lessCompil",
    "build:commun": "env SESATHEQUE_CONF=commun npm run build",
    "build:commun:dev": "env SESATHEQUE_CONF=commun npm run build:dev",
    "build:commun:watch": "env SESATHEQUE_CONF=commun npm run build:watch",
    "build:dev": "webpack --debug --verbose",
    "build:watch": "webpack --debug --verbose -w",
    "deploy:dev": "pm2 _private/pm2Deploy.json5 dev",
    "cli": "echo 'lancer app/cli.js'",
    "doc": "./scripts/doc -a",
    "localInstall": "node scripts/npmi.js",
    "lint": "eslint --ignore-path .gitignore app",
    "maj": "git pull && npm install && npm run build",
    "start": "node app/index.js",
    "start:commun": "env SESATHEQUE_CONF=commun node app/index.js",
    "start:both": "npm start & npm run start:commun",
    "start:dev": "node_modules/nodemon/bin/nodemon.js -e js --legacy-watch --watch app --watch _private app/index.js",
    "start:devcommun": "env SESATHEQUE_CONF=commun node_modules/nodemon/bin/nodemon.js -e js --legacy-watch --watch app --watch _private app/index.js",
    "startClient": "hjs-dev-server",
    "test": "mocha",
    "test:app": "mocha test/app.Test.js",
    "test:tools": "mocha --recursive test/tools",
    "test:watch": "npm test -- --watch",
    "dev": "./scripts/run -sd",
    "prod": "./scripts/run -sp",
    "stop": "./scripts/run -s",
    "watch": "./scripts/run -swl"
  },
  "babel": {
    "presets": [
      [
        "env",
        {
          "targets": {
            "browsers": [
              "ie 11",
              "last 3 iOS versions",
              "last 3 Safari versions",
              "last 3 Android versions"
            ],
            "uglify": true
          },
          "useBuiltIns": true
        }
      ]
    ],
    "plugins": [
      "transform-object-rest-spread",
      "transform-object-assign"
    ]
  },
  "dependencies": {
    "an-flow": "git://src.sesamath.net/an-flow#2.0.7",
    "an-log": "git://src.sesamath.net/an-log#3.1.0",
    "an-uuid": "git://src.sesamath.net/an-uuid#1.0.4",
    "elementtree": "0.1.6",
    "jquery": "3.2.1",
    "jstree": "3.3.4",
    "lassi": "Sesamath/lassi#2.2.0",
    "lodash": "4.16.4",
    "memcached": "2.2.2",
    "moment": "2.18.1",
    "morgan": "1.9.0",
    "request": "2.81.0",
    "sesaeditgraphe": "git://src.sesamath.net/sesaeditgraphe#0.1.25",
    "sesajstools": "git://src.sesamath.net/sesajstools#1.0.15",
    "sesalab-sso": "Sesamath/sesalab-sso#1.0.12",
    "sesatheque-client": "Sesamath/sesatheque-client#1.2.31"
  },
  "devDependencies": {
    "amdefine": "^1.0.1",
    "babel-core": "6.26.0",
    "babel-loader": "6.4.1",
    "babel-preset-env": "1.6.1",
    "babel-plugin-transform-object-rest-spread": "6.26.0",
    "babel-plugin-transform-object-assign": "6.22.0",
    "chai": "^3.5.0",
    "chai-as-promised": "^6.0.0",
    "copy-webpack-plugin": "4.0.1",
    "css-loader": "0.26.1",
    "eslint": "^3.19.0",
    "eslint-config-standard": "^6.2.1",
    "eslint-plugin-promise": "^3.5.0",
    "eslint-plugin-standard": "^2.3.1",
    "extract-text-webpack-plugin": "1.0.1",
    "faker": "^3.1.0",
    "file-loader": "0.10.1",
    "ink-docstrap": "^1.3.0",
    "jsdoc": "3.4.3",
    "knex": "0.7.6",
    "less": "2.7.2",
    "less-plugin-clean-css": "1.5.1",
    "mocha": "^3.4.2",
    "nodemon": "^1.11.0",
    "sinon": "^1.17.7",
    "sinon-chai": "^2.11.0",
    "style-loader": "0.13.2",
    "supertest": "^3.0.0",
    "url-loader": "0.5.7",
    "webpack": "1.14.0",
    "xmlhttprequest": "1.8.0",
    "xml2js": "0.4.17"
  },
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "globals": {
      "lassi": true,
      "log": true
    }
  }
}
