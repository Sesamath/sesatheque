{
  "name": "Sesatheque",
  "version": "1.1.28",
  "engines": {
    "node": ">6"
  },
  "private": true,
  "license": "AGPL-3.0",
  "repository": {
    "type": "git+ssh",
    "url": "git@src.sesamath.net:sesatheque"
  },
  "scripts": {
    "build": "webpack",
    "build:commun": "env SESATHEQUE_CONF=commun npm run build",
    "build:commun:dev": "env SESATHEQUE_CONF=commun npm run build:dev",
    "build:commun:watch": "env SESATHEQUE_CONF=commun npm run build:watch",
    "build:dev": "webpack --debug --verbose",
    "build:watch": "webpack --debug --verbose -w",
    "deploy:dev": "pm2 _private/pm2Deploy.json5 dev",
    "cli": "app/server/cli.js -h",
    "doc": "./scripts/doc -a",
    "localInstall": "node scripts/npmi.js",
    "lint": "eslint --ignore-path .gitignore --ignore-pattern jsdoc .",
    "maj": "git pull && npm install && npm run build",
    "mongo": "./scripts/mongoApp",
    "start": "node app/server/start.js",
    "start:commun": "env SESATHEQUE_CONF=commun node app/server/start.js",
    "start:both": "npm start & npm run start:commun",
    "start:dev": "node_modules/nodemon/bin/nodemon.js -e js --legacy-watch --watch app --watch _private app/start.js --ignore app/main/public/vendor",
    "start:devcommun": "env SESATHEQUE_CONF=commun node_modules/nodemon/bin/nodemon.js -e js --legacy-watch --watch app --watch _private app/start.js --ignore app/main/public/vendor",
    "startClient": "hjs-dev-server",
    "start:testBoth": "npm run start:testBibli & npm run start:testCommun",
    "start:testBibli": "env SESATHEQUE_CONF=testBibli node app/start.js",
    "start:testCommun": "env SESATHEQUE_CONF=testCommun node app/start.js",
    "test": "mocha 'test/**/*.test.js'",
    "test:app": "mocha 'test/app/**/*.test.js'",
    "test:tools": "mocha --recursive test/tools",
    "test:watch": "npm test -- --watch",
    "dev": "./scripts/run -sd",
    "prod": "./scripts/run -sp",
    "stop": "./scripts/run -s",
    "watch": "./scripts/run -swl"
  },
  "babel": {
    "presets": [
      [
        "env",
        {
          "targets": {
            "browsers": [
              "ie 11",
              "last 3 iOS versions",
              "last 3 Safari versions",
              "last 3 Android versions"
            ],
            "uglify": true
          },
          "useBuiltIns": true
        }
      ]
    ],
    "plugins": [
      "transform-object-rest-spread",
      "transform-object-assign"
    ]
  },
  "dependencies": {
    "an-flow": "git://src.sesamath.net/an-flow#2.0.8",
    "an-log": "git://src.sesamath.net/an-log#3.1.4",
    "an-uuid": "git://src.sesamath.net/an-uuid#1.0.5",
    "body-parser": "^1.18.2",
    "elementtree": "0.1.6",
    "express": "^4.16.2",
    "ip": "^1.1.5",
    "lassi": "Sesamath/lassi#2.2.16",
    "lodash": "4.17.5",
    "moment": "2.19.3",
    "morgan": "1.9.0",
    "request": "2.82.0",
    "sesaeditgraphe": "git://src.sesamath.net/sesaeditgraphe#1.0.5",
    "sesajstools": "git://src.sesamath.net/sesajstools#1.0.21",
    "sesalab-sso": "Sesamath/sesalab-sso#1.0.12",
    "sesatheque-client": "Sesamath/sesatheque-client#1.2.47"
  },
  "devDependencies": {
    "amdefine": "^1.0.1",
    "babel-core": "^6.26.0",
    "babel-loader": "6.4.1",
    "babel-preset-env": "^1.6.1",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "babel-plugin-transform-object-assign": "^6.22.0",
    "babel-polyfill": "^6.26.0",
    "bugsnag-js": "^4.4.0",
    "chai": "^3.5.0",
    "chai-as-promised": "^6.0.0",
    "copy-webpack-plugin": "4.0.1",
    "css-loader": "0.26.1",
    "less-loader": "2.2.3",
    "extract-text-webpack-plugin": "1.0.1",
    "faker": "^3.1.0",
    "file-loader": "0.10.1",
    "ink-docstrap": "^1.3.0",
    "jquery": "3.2.1",
    "jquery-ui": "^1.12.1",
    "jsdoc": "^3.5.5",
    "json-loader": "^0.5.7",
    "jstree": "3.3.4",
    "less": "2.7.2",
    "less-plugin-clean-css": "1.5.1",
    "mocha": "^5.1.0",
    "nodemon": "^1.12.4",
    "sinon": "^4.5.0",
    "sinon-chai": "^3.0.0",
    "style-loader": "0.13.2",
    "supertest": "^3.0.0",
    "url-loader": "0.5.7",
    "webpack": "1.15.0",
    "xmlhttprequest": "1.8.0",
    "xml2js": "0.4.17"
  },
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "globals": {
      "lassi": true,
      "log": true
    },
    "overrides": [
      {
        "files": "test/**/*.js",
        "rules": {
          "no-unused-expressions": "off"
        },
        "env": {
          "mocha": true
        }
      }
    ]
  }
}
