{
  "name": "Sesatheque",
  "version": "0.0.65",
  "engines": {
    "node": ">4.4.0"
  },
  "private": true,
  "license": "AGPL-3.0",
  "repository": {
    "type": "git+ssh",
    "url": "git@src.sesamath.net:sesatheque"
  },
  "scripts": {
    "start": "node app/index.js",
    "test": "./scripts/run_tests -a",
    "test:watch": "npm test -- --watch",
    "build": "webpack",
    "build-dev": "webpack --debug --verbose",
    "build-watch": "webpack --debug --verbose -w",
    "deploy-dev": "pm2 _private/pm2Deploy.json5 dev",
    "lint": "standard --verbose | snazzy",
    "maj": "git pull && npm install && npm run build",
    "startClient": "hjs-dev-server",
    "dev": "./scripts/run -sd",
    "prod": "./scripts/run -sp",
    "stop": "./scripts/run -s",
    "watch": "./scripts/run -swl"
  },
  "babel": {
    "presets": [
      "es2015",
      "stage-2"
    ],
    "plugins": []
  },
  "standard": {
    "globals": [
      "describe",
      "it",
      "isProd",
      "lassi",
      "log"
    ],
    "ignore": [
      "node_modules/*",
      "app/*/public/*",
      "app/sesalab-admin",
      "jsdoc/*"
    ]
  },
  "dependencies": {
    "an-flow": "^2.0.1",
    "an-log": "^3.0.4",
    "an-uuid": "^1.0.0",
    "elementtree": "0.1.6",
    "lassi": "git://src.sesamath.net/lassi#2.0.15",
    "lodash": "4.16.4",
    "memcached": "^2.1.0",
    "moment": "2.15.1",
    "morgan": "1.7.0",
    "request": "2.75.0",
    "sesaeditgraphe": "git://src.sesamath.net/sesaeditgraphe#0.1.0",
    "sesajstools": "git://src.sesamath.net/sesajstools#1.0.3",
    "sesalab-sso": "git://src.sesamath.net/sesalab-sso#1.0.0",
    "sesatheque-client": "git://src.sesamath.net/sesatheque-client#1.0.48"
  },
  "devDependencies": {
    "babel-cli": "^6.16.0",
    "babel-core": "^6.17.0",
    "babel-eslint": "^7.0.0",
    "babel-loader": "^6.2.5",
    "babel-preset-es2015": "^6.16.0",
    "babel-preset-stage-2": "^6.17.0",
    "chai": "^3.5.0",
    "chai-as-promised": "^6.0.0",
    "eslint": "^3.8.1",
    "file-loader": "0.8.5",
    "hjs-webpack": "^7.3.0",
    "ink-docstrap": "^1.1.4",
    "jsdoc": "^3.4.0",
    "knex": "^0.7.6",
    "less": "^2.7.1",
    "less-plugin-clean-css": "^1.5.0",
    "mocha": "^3.1.2",
    "mysql": "^2.6.0",
    "sinon": "^1.17.6",
    "sinon-chai": "^2.8.0",
    "snazzy": "^5.0.0",
    "standard": "^6.0.8",
    "url-loader": "^0.5.7",
    "webpack": "^1.12.2",
    "xml2js": "^0.4.4"
  },
  "eslintConfig": {
    "extends": [
      "standard"
    ],
    "globals": {
      "lassi": true,
      "log": true
    }
  }
}
